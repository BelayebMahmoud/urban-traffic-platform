{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/urban-traffic-platform/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/urban-traffic-platform/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/urban-traffic-platform",
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "incident-service": {
      "type": "application",
      "root": "apps/incident-service",
      "entryFile": "main",
      "sourceRoot": "apps/incident-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/incident-service/tsconfig.app.json"
      }
    },
    "notification-service": {
      "type": "application",
      "root": "apps/notification-service",
      "entryFile": "main",
      "sourceRoot": "apps/notification-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification-service/tsconfig.app.json"
      }
    },
    "prisma-client": {
      "type": "library",
      "root": "libs/prisma-client",
      "entryFile": "index",
      "sourceRoot": "libs/prisma-client/src",
      "compilerOptions": {
        "tsConfigPath": "libs/prisma-client/tsconfig.lib.json"
      }
    },
    "traffic-service": {
      "type": "application",
      "root": "apps/traffic-service",
      "entryFile": "main",
      "sourceRoot": "apps/traffic-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/traffic-service/tsconfig.app.json"
      }
    },
    "urban-traffic-platform": {
      "type": "application",
      "root": "apps/urban-traffic-platform",
      "entryFile": "main",
      "sourceRoot": "apps/urban-traffic-platform/src",
      "compilerOptions": {
        "tsConfigPath": "apps/urban-traffic-platform/tsconfig.app.json"
      }
    },
    "vehicle-service": {
      "type": "application",
      "root": "apps/vehicle-service",
      "entryFile": "main",
      "sourceRoot": "apps/vehicle-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/vehicle-service/tsconfig.app.json"
      }
    }
  }
}