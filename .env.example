# ================================================================
# .env.example — Urban Traffic Platform
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ================================================================

# ── Database (MySQL 8) ──────────────────────────────────────────
# Local development with XAMPP:
DATABASE_URL="mysql://root:@localhost:3306/urban_traffic"
# With password:
# DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/urban_traffic"
# Docker Compose:
# DATABASE_URL="mysql://root:urban_pass@mysql:3306/urban_traffic"

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# ── Service Ports ───────────────────────────────────────────────
# Only API_GATEWAY_PORT matters for the running app (modular monolith).
# The individual service ports are reserved for potential future extraction.
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
VEHICLE_SERVICE_PORT=3002
TRAFFIC_SERVICE_PORT=3003
INCIDENT_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005

# ── Frontend ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3000"

# ── Docker Compose (for docker-compose.yml) ─────────────────────
# Used only when running via docker compose — not needed for local dev.
DB_USER=urban_user
DB_PASSWORD=urban_pass
DB_NAME=urban_traffic
DB_PORT=3306

# ── CI (for docker-compose.test.yml) ────────────────────────────
# Set these as GitHub Secrets in your repository settings:
#   MYSQL_ROOT_PASSWORD  — MySQL root password
#   MYSQL_DATABASE       — e.g. urban_traffic_test
#   JWT_SECRET           — JWT signing secret
