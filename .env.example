# Database (PostgreSQL via Docker)
DATABASE_URL="postgresql://urban_user:urban_pass@localhost:5432/urban_traffic"

# DB credentials (used by docker-compose)
DB_USER=urban_user
DB_PASSWORD=urban_pass
DB_NAME=urban_traffic
DB_PORT=5432

# PGAdmin
PGADMIN_EMAIL=admin@urban.local
PGADMIN_PASSWORD=admin123

# JWT
JWT_SECRET="change-this-secret"
JWT_EXPIRES_IN="7d"

# Ports services
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
VEHICLE_SERVICE_PORT=3002
TRAFFIC_SERVICE_PORT=3003
INCIDENT_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000
